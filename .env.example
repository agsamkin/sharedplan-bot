# Telegram Bot API token (получить у @BotFather)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# PostgreSQL connection string (async driver asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/sharedplan

# OpenRouter API key для LLM-парсинга событий (опционально — без ключа работает только ручное создание событий в Mini App)
# OPENROUTER_API_KEY=sk-or-v1-...

# Модель OpenRouter для парсинга (опционально, требуется вместе с OPENROUTER_API_KEY)
# OPENROUTER_MODEL=openai/gpt-4o-mini

# Nexara API key для speech-to-text (опционально — без ключа голосовой ввод отключён)
# NEXARA_API_KEY=sk-...

# Telegram ID владельца бота (число). Владелец всегда имеет доступ к боту.
OWNER_TELEGRAM_ID=123456789

# Часовой пояс для всех операций (по умолчанию Europe/Moscow)
# TIMEZONE=Europe/Moscow

# Интервал проверки напоминаний в секундах (по умолчанию 30)
# REMINDER_CHECK_INTERVAL_SECONDS=30

# URL Mini App для Telegram WebApp кнопок (например, https://yourdomain.com)
# MINI_APP_URL=https://yourdomain.com

# Порт для Mini App web server (по умолчанию 8080)
# MINI_APP_PORT=8080
